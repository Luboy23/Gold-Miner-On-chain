{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "author": "lllu_23 <lllu238744@gmail.com>",
  "type": "module",
  "scripts": {
    "assets:hd": "node ../scripts/generate-hd-runtime-assets.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src",
    "test:e2e:smoke": "playwright test --config=playwright.config.ts tests/e2e/smoke.spec.ts",
    "test:e2e:smoke:attached": "PLAYWRIGHT_NO_WEBSERVER=1 playwright test --config=playwright.config.ts tests/e2e/smoke.spec.ts",
    "test:stability": "playwright test --config=playwright.config.ts",
    "test:stability:long": "playwright test --config=playwright.config.ts --grep @long-play"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "viem": "^2.48.4"
  }
}
